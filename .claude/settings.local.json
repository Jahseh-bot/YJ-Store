{
  "mcpServers": {
    "chrome-mcp-server": {
      "type": "streamableHttp",
      "url": "http://127.0.0.1:12306/mcp"
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ]
    },
    "fetch": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-fetch"
      ]
    }
  },
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(git *)",
      "Bash(npx *)",
      "Bash(curl -s *)",
      "Bash(netstat -ano)",
      "Bash(findstr *)",
      "Bash(type *)",
      "Bash(npx ts-node:*)",
      "Bash(node progress-tracker.js show)",
      "Bash(node progress-tracker.js mark 1.1)",
      "Bash(find C:/Users/MY/Desktop/Projects/marketplace/apps/api/src -type f -name *.ts)",
      "Bash(pnpm install:*)",
      "Bash(find C:/Users/MY/Desktop/Projects/marketplace/apps/web/src -type f -name *.vue -o -name *.ts)",
      "Bash(find C:/Users/MY/Desktop/Projects/marketplace/apps/admin/src -type f -name *.vue -o -name *.tsx -o -name *.ts)"
    ]
  },
  "hooks": {
    "BeforeCommand": [
      {
        "match": "pnpm build",
        "prompt": "正在构建项目，请确保所有项目配置正确"
      }
    ],
    "AfterCommand": [
      {
        "match": "pnpm dev",
        "prompt": "开发服务器已启动，可通过Turbo监控各服务状态"
      }
    ]
  }
}
